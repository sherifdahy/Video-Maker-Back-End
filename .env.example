# ═══════════════════════════════════════════════════════════
# Backend Environment Variables
# ═══════════════════════════════════════════════════════════

# Server Configuration
PORT=3001
NODE_ENV=production

# Frontend URL (CORS)
# Local Development
FRONTEND_URL=http://localhost:5173

# Production (Vercel)
# FRONTEND_URL=https://your-domain.vercel.app

# File Upload Limits
MAX_FILE_SIZE=104857600

# Storage
TMP_DIR=./tmp
OUTPUT_DIR=./output
UPLOAD_DIR=./uploads

# External Services (Optional)
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
